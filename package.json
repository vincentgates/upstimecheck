{
  "name": "md-app-starter",
  "version": "1.0.0",
  "description": "Simple workflow for working with and customizing Bootstrap 5 and intrgration for flask projects",
  "main": "index.js",
  "scripts": {
    "start": "npm-run-all --parallel  sass:watch browsersync",
    "sass:build": "sass resources/scss/main.scss:app/static/css/main.css --no-source-map --style compressed -q",
    "sass:watch": "sass resources/scss/main.scss:app/static/css/main.css --watch -q",
    "browsersync": "browser-sync start --proxy \"localhost:5000\" --files \"app/static/css/*.css\""
  },
  "author": "Vincent Gates",
  "license": "MIT",
  "devDependencies": {
    "npm-run-all": "*",
    "@fortawesome/fontawesome-free": "^6.4.0",
    "@mdi/font": "^7.4.47",
    "bootstrap": "^5.3.3",
    "sass": "*"
  }
}
